# Fan Club Z - Staging Environment Variables (variable names only, no secrets)
# Copy to .env.staging and fill in staging values.

# CLIENT (VITE_* - baked into frontend at build)
VITE_APP_ENV=staging
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_BASE_URL=
VITE_FRONTEND_URL=

# SERVER (backend only)
APP_ENV=staging
CORS_ALLOWLIST=
SUPABASE_SERVICE_ROLE_KEY=
JWT_SECRET=
