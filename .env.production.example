# Fan Club Z - Production Environment Variables (variable names only, no secrets)
# Copy to .env.production and fill in production values.
# Never commit .env.production; set via Vercel/Render env UI.

# CLIENT (VITE_* - baked into frontend at build)
VITE_APP_ENV=production
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_BASE_URL=
VITE_FRONTEND_URL=

# SERVER (backend only)
APP_ENV=production
CORS_ALLOWLIST=
SUPABASE_SERVICE_ROLE_KEY=
JWT_SECRET=
