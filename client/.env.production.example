# Fan Club Z - Client Production Environment (template)
# Copy to .env.production and fill in values. Used by: vite build (production mode)

VITE_API_BASE_URL=https://fan-club-z.onrender.com
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_URL=https://app.fanclubz.app
VITE_FRONTEND_URL=https://app.fanclubz.app

# Performance
VITE_STRIP_LOGS=1
VITE_ENABLE_SW=1
