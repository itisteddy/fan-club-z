# Fan Club Z - Root Environment Example
# Copy to .env.local and fill in values. Never commit secrets.

# ============================================
# CLIENT (VITE_* - baked into frontend at build)
# ============================================
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_BASE_URL=
VITE_FRONTEND_URL=

# ============================================
# SERVER (backend only; never exposed to client)
# ============================================
APP_ENV=local
CORS_ALLOWLIST=http://localhost:3000,http://localhost:5173,http://localhost:5174
SUPABASE_SERVICE_ROLE_KEY=
JWT_SECRET=
